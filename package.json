{
  "name": "claude-gemini-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "A local CLI bridge that lets Claude Code delegate work to Gemini CLI with session summaries.",
  "type": "module",
  "bin": {
    "claude-gemini": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps ./dist/cli.js",
    "watch": "tsc -w -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.3"
  }
}
